FLASK_ENV=development
SECRET_KEY=change-me
API_TITLE=Developer Landing API
API_VERSION=v1
CORS_ORIGINS=http://localhost:3000
TRUST_PROXY_HOPS=0
DATABASE_URL=sqlite:///contacts.db
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# AI is optional: without a key, the service uses a deterministic fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna
AI_TIMEOUT_SECONDS=10

# console logs email previews locally; smtp sends real messages.
EMAIL_MODE=console
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=no-reply@example.com
OWNER_EMAIL=owner@example.com

RATELIMIT_STORAGE_URI=memory://
CONTACT_RATE_LIMIT=5 per 15 minutes
METRICS_API_KEY=replace-with-a-long-random-value
